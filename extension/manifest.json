{
  "manifest_version": 3,
  "name": "Caramel Popcorn — AI Fashion & Beauty Inspiration",
  "short_name": "Caramel Popcorn",
  "version": "1.0.0",
  "description": "Save fashion & beauty finds from Pinterest, Instagram, Nykaa, Myntra, Amazon, Zara, H&M, Sephora, Tira and more. Outfits decoded. One cozy home for everything you love.",
  "action": {
    "default_title": "Caramel Popcorn",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "assets/icon16.png",
      "32":  "assets/icon32.png",
      "48":  "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16":  "assets/icon16.png",
    "32":  "assets/icon32.png",
    "48":  "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "contextMenus", "notifications"],
  "host_permissions": [
    "https://*.amazon.in/*",
    "https://*.amazon.com/*",
    "https://*.nykaa.com/*",
    "https://*.myntra.com/*",
    "https://*.ajio.com/*",
    "https://*.zara.com/*",
    "https://*.hm.com/*",
    "https://*.sephora.com/*",
    "https://*.tirabeauty.com/*",
    "https://*.pinterest.com/*",
    "https://*.instagram.com/*",
    "https://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.in/*",
        "https://*.amazon.com/*",
        "https://*.nykaa.com/*",
        "https://*.myntra.com/*",
        "https://*.ajio.com/*",
        "https://*.zara.com/*",
        "https://*.hm.com/*",
        "https://*.sephora.com/*",
        "https://*.tirabeauty.com/*",
        "https://*.pinterest.com/*",
        "https://*.instagram.com/*",
        "https://*.youtube.com/*"
      ],
      "js": ["content-scripts/inject.js"],
      "css": ["content-scripts/inject.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dashboard/dashboard.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
